{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish src/RouteOps.API/RouteOps.API.csproj -c Release -o /app/out"
  },
  "deploy": {
    "startCommand": "dotnet /app/out/RouteOps.API.dll",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}